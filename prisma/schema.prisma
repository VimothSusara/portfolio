// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectLifecycle {
  PLANNING
  IN_PROGRESS
  COMPLETED
}

enum ProjectType {
  WEBSITE
  APPLICATION
  GAME
  OTHER
}

enum ContactMessageStatus {
  PENDING
  READ
  ARCHIVED
  SPAM
}

enum SyncJobType {
  GITHUB_REPOSITORIES
  GITHUB_SNAPSHOTS
  ORGANIZATION_ACTIVITY
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  email       String    @unique
  password    String
  role        Role      @default(USER)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  medias      Media[]

  @@index([email])
  @@index([username])
}

model Profile {
  id           String   @id @default(cuid())
  fullName     String
  title        String
  shortBio     String
  longBio      String   @db.Text
  email        String
  location     String?
  resumeUrl    String?
  avatarUrl    String?
  heroImageUrl String?
  githubUrl    String?
  linkedinUrl  String?
  twitterUrl   String?
  websiteUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Project {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  shortDescription String
  description      String           @db.Text
  githubUrl        String?
  liveUrl          String?
  featured         Boolean          @default(false)
  status           ProjectStatus    @default(DRAFT)
  lifecycle        ProjectLifecycle @default(PLANNING)
  type             ProjectType      @default(OTHER)

  thumbnailImageId String?
  githubRepositoryId String?
  startedAt        DateTime?
  completedAt      DateTime?
  publishedAt      DateTime?
  sortOrder        Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  technologies   ProjectTechnology[]
  thumbnailImage Media?              @relation("ProjectThumbnail", fields: [thumbnailImageId], references: [id], onDelete: SetNull)
  githubRepository GithubRepository? @relation(fields: [githubRepositoryId], references: [id], onDelete: SetNull)
  images         ProjectImage[]
  snapshots      GithubSnapshot[]
  views          ProjectView[]

  @@index([slug])
  @@index([status])
  @@index([lifecycle])
  @@index([type])
}

model Technology {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  iconName   String?
  iconUrl    String?
  websiteUrl String?
  category   String?
  createdAt  DateTime @default(now())

  projects ProjectTechnology[]

  @@index([slug])
}

model ProjectTechnology {
  projectId    String
  technologyId String

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([projectId, technologyId])
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  storagePath  String
  publicUrl    String
  mimeType     String
  width        Int?
  height       Int?
  fileSize     Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy    User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  projectImages ProjectImage[]
  thumbnailFor  Project[]      @relation("ProjectThumbnail")
  coverFor      BlogPost[]     @relation("BlogPostCover")

  @@index([uploadedById])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  mediaId   String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([projectId, sortOrder])
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String               @db.Text
  ipAddress String?
  userAgent String?
  status    ContactMessageStatus @default(PENDING)
  createdAt DateTime             @default(now())

  @@index([status, createdAt])
}

model GithubRepository {
  id         String   @id @default(cuid())
  repoName   String
  ownerName  String
  stars      Int      @default(0)
  forks      Int      @default(0)
  watchers   Int      @default(0)
  openIssues Int      @default(0)
  createdAt  DateTime
  updatedAt  DateTime

  snapshots GithubSnapshot[]
  projects  Project[]

  @@unique([ownerName, repoName])
}

model GithubSnapshot {
  id           String   @id @default(cuid())
  repositoryId String
  stars        Int
  forks        Int
  commits      Int
  openIssues   Int
  capturedAt   DateTime @default(now())
  projectId    String?

  repository GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  project    Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([repositoryId, capturedAt])
  @@index([projectId, capturedAt])
}

model OrganizationActivity {
  id               String   @id @default(cuid())
  organizationName String
  commits          Int      @default(0)
  pullRequests     Int      @default(0)
  reviews          Int      @default(0)
  issues           Int      @default(0)
  capturedAt       DateTime @default(now())

  @@index([organizationName, capturedAt])
}

model SyncJobRun {
  id           String        @id @default(cuid())
  type         SyncJobType
  status       SyncJobStatus @default(PENDING)
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  errorMessage String?       @db.Text
  metadata     Json?

  @@index([type, status, startedAt])
}

model Visitor {
  id        String   @id @default(cuid())
  ipHash    String
  country   String?
  city      String?
  userAgent String?
  createdAt DateTime @default(now())

  pageViews PageView[]

  @@index([ipHash])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String?
  viewedAt  DateTime @default(now())

  visitor Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([path, viewedAt])
  @@index([viewedAt])
}

model ProjectView {
  id        String   @id @default(cuid())
  projectId String
  viewedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, viewedAt])
}

model ResumeDownload {
  id           String   @id @default(cuid())
  ipHash       String?
  downloadedAt DateTime @default(now())

  @@index([downloadedAt])
}

model BlogPost {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String
  content      String    @db.Text
  coverImageId String?
  published    Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  coverImage Media? @relation("BlogPostCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
}

model GithubContributionCache {
  id                 String   @id @default("default")
  username           String
  totalContributions Int
  weeks              Json
  updatedAt          DateTime @updatedAt
}